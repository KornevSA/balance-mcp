# --- balance-mcp configuration ---

PORT=8080

# Внутренний (docker-сеть) базовый URL balance API. Пользовательский токен идёт сюда.
#   dev:  http://web/api/v1        (сервис web в balance/docker-compose.yml)
#   prod: http://balance-web/api/v1
BALANCE_API_BASE=http://balance-web/api/v1

# Публичные OAuth-эндпоинты balance (их открывает браузер Claude).
#   dev:  http://localhost:8080
#   prod: https://balance.99p.ru
BALANCE_OAUTH_PUBLIC=https://balance.99p.ru

# Внутренний адрес balance для introspection (без TLS-hairpin).
#   dev:  http://web
#   prod: http://balance-web
BALANCE_OAUTH_INTERNAL=http://balance-web

# Канонический URL этого MCP-ресурса (audience). То, что вписывают в «Add custom connector».
#   dev:  http://localhost:8088/mcp
#   prod: https://balance.99p.ru/mcp
PUBLIC_URL=https://balance.99p.ru/mcp

# Confidential-клиент самого MCP для /oauth/introspect (создаётся в balance один раз).
MCP_INTROSPECTION_CLIENT_ID=
MCP_INTROSPECTION_CLIENT_SECRET=

# Порог инлайна файла (base64) в ответе тулза, байт (по умолчанию 5 МБ).
MCP_INLINE_MAX_BYTES=5242880
